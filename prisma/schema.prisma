generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- BẢN VẼ CẤU TRÚC DỮ LIỆU ---

// 1. Bảng không gian làm việc chung
model Pool {
  id        String    @id @default(cuid())
  name      String    @default("Ban Truyền thông Chánh Hưng")
  members   User[]
  tasks     Task[]
  messages  Message[] 
}

// 2. Bảng quản lý thành viên
model User {
  id        String    @id // Supabase Auth UID
  email     String    @unique
  name      String?
  avatarUrl String?
  unit      String?   // Đơn vị (VD: Bí thư chi Đoàn KP29)
  role      String    @default("MEMBER") // ADMIN, EDITOR, MEMBER
  poolId    String
  pool      Pool      @relation(fields: [poolId], references: [id])
  tasks     Task[]    @relation("TaskAssignee")
  messages  Message[] @relation("UserMessages")
  posts     Post[]    @relation("UserPosts")
  media     Media[]   @relation("UserMedia")
  meetingRequests MeetingRequest[] @relation("UserMeetingRequests")
  activities Activity[] @relation("UserActivities")
  votes     Vote[]     @relation("UserVotes")
}

// 3. Bảng quản lý thẻ việc Kanban (Trello Card Style)
model Task {
  id          String      @id @default(cuid())
  title       String
  description String?     @db.Text
  status      String      @default("TODO")
  order       Int         @default(0) // Dùng để sắp xếp thẻ (kéo thả)
  priority    String      @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  dueDate     DateTime?
  
  // Tài liệu đính kèm (Lưu link từ Supabase Storage)
  attachments String[]    

  poolId      String
  pool        Pool        @relation(fields: [poolId], references: [id])
  assigneeId  String?
  assignee    User?       @relation("TaskAssignee", fields: [assigneeId], references: [id])
  
  checklists  Checklist[]
  activities  Activity[]  @relation("TaskActivities")
}

model Checklist {
  id          String          @id @default(cuid())
  title       String
  taskId      String
  task        Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  items       ChecklistItem[]
}

model ChecklistItem {
  id          String    @id @default(cuid())
  text        String
  isCompleted Boolean   @default(false)
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
}

model Activity {
  id        String   @id @default(cuid())
  type      String   // 'MOVED', 'COMMENT', 'CREATED', 'COMPLETED'
  text      String
  createdAt DateTime @default(now())
  
  userId    String
  user      User     @relation("UserActivities", fields: [userId], references: [id])
  
  taskId    String
  task      Task     @relation("TaskActivities", fields: [taskId], references: [id], onDelete: Cascade)
}

// 4. Bảng quản lý tin nhắn Chat nội bộ
model Message {
  id          String   @id @default(cuid())
  content     String?  // Nội dung chat hoặc @tag
  type        String   @default("TEXT") // Phân loại: TEXT, IMAGE, FILE
  fileUrl     String?  // Link đính kèm nếu có
  
  poolId      String
  pool        Pool     @relation(fields: [poolId], references: [id])
  
  senderId    String
  sender      User     @relation("UserMessages", fields: [senderId], references: [id])
  
  createdAt   DateTime @default(now())
}

// 5. Bảng lưu trữ kết quả họp trực tuyến
model Meeting {
  id           String   @id @default(cuid())
  topic        String
  startTime    DateTime
  recordingUrl String? 
  summary      String?  // Nơi lưu kết quả AI tóm tắt
}

// 6. Bảng Bài viết sẵn sàng xuất bản (Publishing Bridge)
model Post {
  id          String   @id @default(cuid())
  title       String
  content     String?  @db.Text
  status      String   @default("DRAFT") // DRAFT, PENDING, PUBLISHED
  mediaUrls   String[] // Mảng link ảnh/video đính kèm
  
  authorId    String
  author      User     @relation("UserPosts", fields: [authorId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 7. Bảng quản lý kho tài nguyên Media Pool
model Media {
  id          String   @id @default(cuid())
  name        String
  url         String
  type        String   // IMAGE, VIDEO, DOCUMENT
  size        String?
  tag         String?
  
  uploaderId  String
  uploader    User     @relation("UserMedia", fields: [uploaderId], references: [id])
  
  createdAt   DateTime @default(now())
}

// 8. Thư viện thông tin (Thông báo, Cẩm nang pháp luật, Quy trình...)
model LibraryItem {
  id        String   @id @default(cuid())
  title     String
  category  String   // Ví dụ: Kỹ thuật, Pháp luật, Kịch bản
  content   String   @db.Text
  fileUrl   String?
  createdAt DateTime @default(now())
}

// 9. Đăng ký phòng họp & Duyệt yêu cầu
model MeetingRequest {
  id          String   @id @default(cuid())
  roomName    String
  purpose     String
  startTime   DateTime
  endTime     DateTime
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  requestedBy String
  user        User     @relation("UserMeetingRequests", fields: [requestedBy], references: [id])
  isAIApproved Boolean @default(false) // Đánh dấu nếu AI tự duyệt
  createdAt   DateTime @default(now())
}

// 10. Cấu hình hệ thống động (Lưu API Key để Admin đổi nhanh)
model SystemConfig {
  key   String @id
  value String
}

// 11. Bảng Biểu quyết (VOTING) cho Đội hình
model Poll {
  id          String   @id @default(cuid())
  question    String
  options     Json     // Lưu mảng các lựa chọn: ["Option A", "Option B",...]
  dueDate     DateTime?
  status      String   @default("OPEN") // OPEN, CLOSED
  createdAt   DateTime @default(now())
  votes       Vote[]
}

model Vote {
  id        String @id @default(cuid())
  pollId    String
  poll      Poll   @relation(fields: [pollId], references: [id])
  userId    String
  user      User   @relation("UserVotes", fields: [userId], references: [id])
  optionIdx Int    // Vị trí option được chọn
  
  @@unique([pollId, userId])
}
